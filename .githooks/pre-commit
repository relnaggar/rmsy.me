#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [[ "${SKIP_PRE_COMMIT_LINT:-0}" == "1" ]]; then
  echo "[pre-commit] Skipping Pint lint checks (SKIP_PRE_COMMIT_LINT=1)."
else
  echo "[pre-commit] Running Pint lint checks in Docker..."
  docker compose exec -T app bash -lc "cd /var/www && vendor/bin/pint --test"
fi
